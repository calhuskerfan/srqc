{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithThreadId" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {ThreadId,3} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AppSettings": {
    "MinProcessingDelay": 300,
    "MaxProcessingDelay": 500
  },
  "ConduitConfig": {
    "PodCount": 7,
    "ReUsePods": true,
    "TransformerFactoryType": "Processor.Transformers.DefaultTransformerFactory"
  },
  "InboundChannel": {
    "Name": "in-queue",
    "PrefetchCount": 6
  },
  "OutboundChannel": {
    "Name": "out-queue"
  }
}
